# ANPL Site Environment Variables
# Copy this file to .env and fill in your values

# Password you enter at /admin to manage credentials
ADMIN_PASSWORD=your_admin_password_here

# Port for local development (optional, defaults to 3000)
PORT=3000

# Your deployed URL — no trailing slash
BASE_URL=https://courseplatform-production-a564.up.railway.app

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Resend (email) — get free API key at resend.com ---
RESEND_API_KEY=re_...
EMAIL_FROM=hello@anpl.co

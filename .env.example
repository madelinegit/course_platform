# ANPL Site Environment Variables
# Copy this file to .env and fill in your values

# Password students enter at /course to access the course
COURSE_PASSWORD=your_course_password_here

# Password you enter at /admin to manage credentials
# Make this different from the course password
ADMIN_PASSWORD=your_admin_password_here

# Port for local development (optional, defaults to 3000)
PORT=3000

# --- Vercel Blob (production only) ---
# Required if deploying to Vercel. Create a Blob store in your Vercel project
# dashboard (Storage tab) and paste the token here AND in Vercel env vars.
# Leave blank for local development — the filesystem is used instead.
BLOB_READ_WRITE_TOKEN=

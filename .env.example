# ANPL Site Environment Variables
# Copy this file to .env and fill in your values

# Password students enter at /course to access the course
COURSE_PASSWORD=your_course_password_here

# Password you enter at /admin to manage credentials
# Make this different from the course password
ADMIN_PASSWORD=your_admin_password_here

# Port for local development (optional, defaults to 3000)
PORT=3000
